generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id                String             @id @default(cuid())
  companyName       String
  owner             String
  email             String
  phone             String?
  tier              String             @default("STANDARD")
  services          String
  monthlyRetainer   Int?
  stage             String             @default("LEAD")
  frameioLink       String?
  contractUrl       String?
  startDate         DateTime           @default(now())
  projects          Project[]
  deliverableGroups DeliverableGroup[]
  createdAt         DateTime           @default(now())
}

model Project {
  id               String            @id @default(cuid())
  name             String
  summary          String            @default("")
  status           String            @default("PLANNING")
  kickoffDate      DateTime?
  dueDate          DateTime?
  clientId         String
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks            Task[]
  deliverableGroup DeliverableGroup?
  createdAt        DateTime          @default(now())
}

model Task {
  id          String       @id @default(cuid())
  title       String
  assignee    String       @default("")
  status      String       @default("NOT_STARTED")
  dueDate     DateTime?
  notes       String?
  link        String?
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverable Deliverable?
  createdAt   DateTime     @default(now())
}

model DeliverableGroup {
  id           String        @id @default(cuid())
  name         String
  type         String        @default("GENERAL")
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId    String?       @unique
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  deliverables Deliverable[]
  createdAt    DateTime      @default(now())
}

model Deliverable {
  id        String           @id @default(cuid())
  title     String
  link      String?
  completed Boolean          @default(false)
  groupId   String
  group     DeliverableGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  taskId    String?          @unique
  task      Task?            @relation(fields: [taskId], references: [id], onDelete: SetNull)
  createdAt DateTime         @default(now())
}

model Expense {
  id        String   @id @default(cuid())
  title     String
  amount    Int
  purpose   String?
  month     String
  createdAt DateTime @default(now())
}

model Lead {
  id             String   @id @default(cuid())
  name           String
  phone          String?
  companyName    String?
  readyToInvest  Boolean?
  willingToStart Boolean?
  stage          String   @default("NEW")
  notes          String?
  source         String?
  createdAt      DateTime @default(now())
}

model MonthlyRevenue {
  id        String   @id @default(cuid())
  month     String   @unique
  revenue   Int      @default(0)
  createdAt DateTime @default(now())
}
